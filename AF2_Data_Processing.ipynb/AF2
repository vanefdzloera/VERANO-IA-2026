    {
      "cell_type": "code",
      "source": [
        "#step 2: normalization min-max scaling\n",
        "\n",
        "#step 2.1: clean data\n",
        "df_clean = datos.copy()\n",
        "fix_columns = ['Glucose', 'BloodPressure', 'SkinThickness', 'Insulin', 'BMI']\n",
        "datos_clean = datos.copy()\n",
        "for col in fix_columns:\n",
        "    median_value = df_clean[col].median()\n",
        "    df_clean[col] = df_clean[col].replace(0, median_value)\n",
        "\n",
        "#step2.2 normalization\n",
        "df_normalized = df_clean.copy()\n",
        "\n",
        "for col in df_normalized.columns:\n",
        "    if col != \"Outcome\":\n",
        "        min_v = df_normalized[col].min()\n",
        "        max_v = df_normalized[col].max()\n",
        "        df_normalized[col] = (df_normalized[col] - min_v) / (max_v - min_v)\n",
        "\n",
        "print(df_normalized.head())\n"
      ],
